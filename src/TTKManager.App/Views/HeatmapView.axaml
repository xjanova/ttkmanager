<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TTKManager.App.ViewModels"
             xmlns:models="using:TTKManager.App.Models"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="600"
             x:Class="TTKManager.App.Views.HeatmapView"
             x:DataType="vm:HeatmapViewModel">

    <Design.DataContext><vm:HeatmapViewModel/></Design.DataContext>

    <Grid RowDefinitions="Auto,Auto,Auto">
        <TextBlock Text="Dayparting Heatmap" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentPrimaryBrush}" Margin="0,0,0,10"/>

        <Border Grid.Row="1" Classes="card" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal" Spacing="10">
                <ComboBox Width="240" ItemsSource="{Binding Accounts}" SelectedItem="{Binding SelectedAccount, Mode=TwoWay}">
                    <ComboBox.ItemTemplate><DataTemplate DataType="models:TikTokAccount"><TextBlock Text="{Binding Name}"/></DataTemplate></ComboBox.ItemTemplate>
                </ComboBox>
                <ComboBox Width="140" ItemsSource="{Binding Metrics}" SelectedItem="{Binding Metric, Mode=TwoWay}"/>
                <Button Content="↻ Refresh" Command="{Binding RefreshCommand}"/>
                <TextBlock VerticalAlignment="Center" Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondaryBrush}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Classes="card">
            <ItemsControl ItemsSource="{Binding Cells}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <UniformGrid Rows="7" Columns="24"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="vm:HeatmapCell">
                        <Border Margin="1" Height="38" CornerRadius="3" Background="{StaticResource BgInputBrush}">
                            <Border.Styles>
                                <Style Selector="Border">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <SolidColorBrush Color="#a3e635" Opacity="{Binding Intensity}"/>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Border.Styles>
                            <TextBlock Text="{Binding Display}" FontSize="9" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>
    </Grid>
</UserControl>

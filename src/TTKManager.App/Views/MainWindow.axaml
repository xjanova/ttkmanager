<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TTKManager.App.ViewModels"
        xmlns:views="using:TTKManager.App.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1280" d:DesignHeight="800"
        x:Class="TTKManager.App.Views.MainWindow"
        x:DataType="vm:ShellViewModel"
        Width="1280" Height="800"
        MinWidth="1100" MinHeight="640"
        Icon="/Assets/app.ico"
        Background="{StaticResource BgPrimaryBrush}"
        Title="{Binding Title}">

    <Design.DataContext>
        <vm:ShellViewModel/>
    </Design.DataContext>

    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{StaticResource HeaderGradientBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="20,10">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Image Source="/Assets/logottk.png" Width="32" Height="32"/>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="TTK Manager" FontSize="14" FontWeight="Bold" Foreground="{StaticResource AccentPrimaryBrush}"/>
                        <TextBlock Text="TikTok Marketing API ad scheduler" FontSize="10" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </StackPanel>

                <Border Grid.Column="2" Padding="10,5" CornerRadius="14" VerticalAlignment="Center"
                        Background="{StaticResource BgElevatedBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
                    <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                        <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                            <Ellipse.Styles>
                                <Style Selector="Ellipse"><Setter Property="Fill" Value="{StaticResource TextTertiaryBrush}"/></Style>
                            </Ellipse.Styles>
                        </Ellipse>
                        <TextBlock Text="{Binding DemoStatusLabel}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center"/>
                        <Button Content="{Binding DemoButtonLabel}" Command="{Binding ToggleDemoCommand}" Classes="accent" Padding="10,4"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid ColumnDefinitions="280,*">

            <Border Grid.Column="0" Background="{StaticResource BgPrimaryBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <ScrollViewer>
                    <ListBox ItemsSource="{Binding Items}" SelectedItem="{Binding Selected, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="6">
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="vm:NavSection">
                                <Grid ColumnDefinitions="22,*,Auto" Height="32">
                                    <TextBlock Grid.Column="0" Text="{Binding Emoji}" VerticalAlignment="Center" FontSize="13"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Title}" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextPrimaryBrush}" Margin="6,0"/>
                                    <Border Grid.Column="2" Padding="6,2" CornerRadius="8" Background="{StaticResource BgElevatedBrush}" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Phase}" FontSize="9" Foreground="{StaticResource TextSecondaryBrush}"/>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </ScrollViewer>
            </Border>

            <Border Grid.Column="1" Padding="20" Background="{StaticResource BgPrimaryBrush}">
                <ContentControl Content="{Binding Current}"/>
            </Border>

        </Grid>
    </DockPanel>
</Window>

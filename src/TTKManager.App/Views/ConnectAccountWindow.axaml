<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:TTKManager.App.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="660" d:DesignHeight="500"
        x:Class="TTKManager.App.Views.ConnectAccountWindow"
        x:DataType="vm:ConnectAccountViewModel"
        Width="680" Height="540"
        Icon="/Assets/app.ico"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{StaticResource BgPrimaryBrush}"
        Title="Connect TikTok Ad Account">

    <Design.DataContext>
        <vm:ConnectAccountViewModel/>
    </Design.DataContext>

    <DockPanel Margin="20">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="14" Margin="0,0,0,12">
            <Image Source="/Assets/logottk.png" Width="48" Height="48" VerticalAlignment="Center"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentPrimaryBrush}" Text="Connect TikTok Ad Account"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" TextWrapping="Wrap" Text="Out-of-band OAuth — open the URL, approve, copy the auth_code from the callback page, paste below."/>
            </StackPanel>
        </StackPanel>

        <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0" Spacing="10">
            <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Spacing="10">
                <Button Content="Exchange Code" Command="{Binding ExchangeCodeCommand}" Classes="accent"/>
                <Button Content="Cancel" Click="OnCancelClick"/>
            </StackPanel>
            <TextBlock FontSize="11" Foreground="{StaticResource TextTertiaryBrush}" TextWrapping="Wrap"
                       Text="If your developer app has not been approved, the Marketing API will return errors. Set UseMockApi=true in appsettings.local.json for local UI testing."/>
        </StackPanel>

        <StackPanel Spacing="14">
            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource AccentLightBrush}" Text="1. Authorization URL"/>
                    <TextBox Text="{Binding AuthorizationUrl}" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas,Menlo,monospace" FontSize="11"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Open in Browser" Command="{Binding OpenAuthorizationUrlCommand}"/>
                        <Button Content="Copy URL" Command="{Binding CopyUrlCommand}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <Border Classes="card">
                <StackPanel Spacing="8">
                    <TextBlock FontWeight="SemiBold" Foreground="{StaticResource AccentLightBrush}" Text="2. Paste authorization code"/>
                    <TextBox Text="{Binding PastedCode, Mode=TwoWay}" Watermark="Paste auth_code from the callback page"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </DockPanel>
</Window>

<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:TTKManager.App.ViewModels"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="900" d:DesignHeight="500"
             x:Class="TTKManager.App.Views.CsvView"
             x:DataType="vm:CsvViewModel">

    <Design.DataContext><vm:CsvViewModel/></Design.DataContext>

    <StackPanel Spacing="14">
        <TextBlock Text="CSV Import / Export" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentPrimaryBrush}"/>

        <UniformGrid Columns="2" Rows="1">
            <Border Classes="card" Margin="0,0,8,0">
                <StackPanel Spacing="8">
                    <TextBlock Text="⤓ Export" FontWeight="SemiBold" Foreground="{StaticResource AccentLightBrush}"/>
                    <Button Content="Export schedule rules to CSV" Command="{Binding ExportSchedulesCommand}" HorizontalAlignment="Stretch" Classes="accent"/>
                    <Button Content="Export audit log (10k rows)" Command="{Binding ExportAuditCommand}" HorizontalAlignment="Stretch"/>
                    <Button Content="Export accounts (no tokens)" Command="{Binding ExportAccountsCommand}" HorizontalAlignment="Stretch"/>
                </StackPanel>
            </Border>

            <Border Classes="card" Margin="8,0,0,0">
                <StackPanel Spacing="8">
                    <TextBlock Text="⤒ Import" FontWeight="SemiBold" Foreground="{StaticResource AccentLightBrush}"/>
                    <Button Content="Import schedule rules from CSV" Command="{Binding ImportSchedulesCommand}" HorizontalAlignment="Stretch"/>
                    <TextBlock TextWrapping="Wrap" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                               Text="CSV format: Id,AdvertiserId,CampaignId,Name,Action,BudgetAmount,Cron,TimeZoneId,Enabled,CreatedAt — Id and CreatedAt are ignored on import."/>
                </StackPanel>
            </Border>
        </UniformGrid>

        <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource AccentLightBrush}"/>
    </StackPanel>
</UserControl>
